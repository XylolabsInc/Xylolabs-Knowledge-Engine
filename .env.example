# xylolabs-kb Configuration
# Copy to .env and fill in your values

# =============================================================================
# General
# =============================================================================
LOG_LEVEL=info
DB_PATH=./data/xylolabs-kb.db
ATTACHMENT_PATH=./data/attachments

# =============================================================================
# API Server
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8080

# =============================================================================
# Slack
# =============================================================================
SLACK_ENABLED=true
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_SYNC_INTERVAL=60s
# Comma-separated channel IDs to monitor (empty = all channels the bot is in)
SLACK_CHANNELS=

# =============================================================================
# Google Workspace
# =============================================================================
GOOGLE_ENABLED=false
GOOGLE_CREDENTIALS_FILE=./credentials.json
GOOGLE_TOKEN_FILE=./token.json
GOOGLE_SYNC_INTERVAL=5m
# Comma-separated Drive folder IDs to index (empty = all accessible)
GOOGLE_DRIVE_FOLDERS=
GOOGLE_IMPERSONATE_EMAIL=  # Email to impersonate for Gmail sending (required for send_email tool)

# =============================================================================
# Notion
# =============================================================================
NOTION_ENABLED=false
NOTION_API_KEY=ntn_your-api-key
NOTION_SYNC_INTERVAL=5m
# Comma-separated root page IDs to index
NOTION_ROOT_PAGES=

# =============================================================================
# Gemini AI (for bot responses and image description)
# =============================================================================
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite-preview
# Custom system prompt file (optional, uses built-in if not set)
# SYSTEM_PROMPT_FILE=./system-prompt.txt

# =============================================================================
# Knowledge Base Repository
# =============================================================================
# Path to the markdown knowledge base Git repo (required for bot responses)
# The bot reads index/detail files from this repo and auto-pulls before each query.
# KB_REPO_DIR=/opt/knowledge

# =============================================================================
# KB Generation (knowledge base curation)
# =============================================================================
# Backend for processing documents into KB: "claude" or "gemini"
KB_BACKEND=gemini
# Gemini model for KB generation (only used when KB_BACKEND=gemini)
KB_GEN_MODEL=gemini-3.1-pro-preview
# Thinking level for Gemini KB generation: none, low, medium, high
KB_GEN_THINKING=high
# API key for KB generation (defaults to GEMINI_API_KEY if not set)
# KB_GEN_API_KEY=
